# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_ID=your_telegram_chat_id_here

# LLM Configuration (NVIDIA NIM)
LLM_API_KEY=your_nvidia_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=z-ai/glm4.7

# LLM Generation Parameters
# Temperature: 0.0-2.0. Lower = more deterministic, higher = more creative
LLM_TEMPERATURE=0.7
# Top-p: 0.0-1.0. Nucleus sampling threshold
LLM_TOP_P=1.0
# Max tokens: maximum response length
LLM_MAX_TOKENS=16384
# Seed: for reproducible outputs
LLM_SEED=42
# Stream: enable streaming responses (true/false)
LLM_STREAM=false

# Thinking/Reasoning Mode
# enable_thinking: whether the model shows its reasoning (true/false)
LLM_ENABLE_THINKING=false
# clear_thinking: whether to clear thinking after response (true/false)
LLM_CLEAR_THINKING=true

# LLM Timeout & Retries
# Timeout in seconds for each API request
LLM_TIMEOUT=60
# Maximum number of retry attempts on failure
LLM_MAX_RETRIES=3
# Delay in seconds between retries
LLM_RETRY_DELAY=2

# Database Configuration
DATABASE_PATH=./data/vault_guardian.db

# Timezone
TIMEZONE=Asia/Kolkata